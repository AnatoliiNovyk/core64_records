PORT=3000
NODE_ENV=development
DATA_BACKEND=firestore
LOG_LEVEL=info
REQUEST_LOGGING_ENABLED=true
REQUEST_LOGGING_MAX_BODY_CHARS=2048
# Firestore project settings (use ADC in Cloud Run or GOOGLE_APPLICATION_CREDENTIALS locally)
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=(default)
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500
ADMIN_PASSWORD=core64admin
# Captcha fallback config (admin settings override these values)
# Supported: none, hcaptcha, recaptcha_v2
CONTACT_CAPTCHA_PROVIDER=none
CONTACT_CAPTCHA_SECRET=
# Admin mutation rate limits
COLLECTIONS_RATE_LIMIT_WINDOW_MS=300000
COLLECTIONS_RATE_LIMIT_MAX=30
SETTINGS_RATE_LIMIT_WINDOW_MS=300000
SETTINGS_RATE_LIMIT_MAX=20
CONTACT_REQUEST_UPDATE_RATE_LIMIT_WINDOW_MS=300000
CONTACT_REQUEST_UPDATE_RATE_LIMIT_MAX=50
# CSP mode: enforce | report-only | both
CSP_MODE=enforce
# CSP report endpoint (relative path or absolute URL)
CSP_REPORT_URI=/api/security/csp-report
